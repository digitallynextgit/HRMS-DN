// =============================================================================
// HRMS Prisma Schema - Phase 1 + Phase 2 + Phase 3 + Phase 4
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  RESIGNED
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ── Attendance ────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
  HOLIDAY
  WEEKEND
}

// ── Leave ─────────────────────────────────────────────────────────────────────

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ── Payroll ───────────────────────────────────────────────────────────────────

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
}

// ── Projects ──────────────────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MemberRole {
  OWNER
  MANAGER
  MEMBER
  VIEWER
}

// ── Performance ───────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  DRAFT
  SELF_REVIEW
  MANAGER_REVIEW
  COMPLETED
  CANCELLED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Recruitment ───────────────────────────────────────────────────────────────

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  ON_HOLD
}

enum ApplicantStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
  TECHNICAL
  HR
}

enum InterviewResult {
  PENDING
  PASSED
  FAILED
  NO_SHOW
}

// ── M12 Attendance sources ─────────────────────────────────────────────────────

enum AttendanceSource {
  DEVICE
  GPS
  QR
  MANUAL
  CSV
}

// ── Documents ─────────────────────────────────────────────────────────────────

enum DocumentCategory {
  IDENTITY
  ACADEMIC
  PROFESSIONAL
  EMPLOYMENT
  TAX
  COMPANY_POLICY
  TEMPLATE
  OTHER
}

// =============================================================================
// NEXT-AUTH MODELS
// =============================================================================

model Account {
  id                String  @id @default(cuid()) @map("id")
  userId            String  @map("user_id")
  type              String  @map("type")
  provider          String  @map("provider")
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text @map("refresh_token")
  access_token      String? @db.Text @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String? @map("scope")
  id_token          String? @db.Text @map("id_token")
  session_state     String? @map("session_state")

  employee Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid()) @map("id")
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @map("expires")

  employee Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String   @map("identifier")
  token      String   @unique @map("token")
  expires    DateTime @map("expires")

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// PBAC - ROLES & PERMISSIONS
// =============================================================================

model Role {
  id          String   @id @default(uuid()) @map("id")
  name        String   @unique @map("name")
  displayName String   @map("display_name")
  description String?  @map("description")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  employeeRoles   EmployeeRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @map("id")
  scope       String   @unique @map("scope")
  module      String   @map("module")
  action      String   @map("action")
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model EmployeeRole {
  id         String  @id @default(uuid()) @map("id")
  employeeId String  @map("employee_id")
  roleId     String  @map("role_id")
  scopeType  String? @map("scope_type")
  scopeId    String? @map("scope_id")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, roleId, scopeType, scopeId])
  @@map("employee_roles")
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String   @id @default(uuid()) @map("id")
  actorId    String?  @map("actor_id")
  action     String   @map("action")
  module     String   @map("module")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  changes    Json?    @map("changes")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor Employee? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// DEPARTMENT & DESIGNATION
// =============================================================================

model Department {
  id          String   @id @default(uuid()) @map("id")
  name        String   @unique @map("name")
  code        String   @unique @map("code")
  description String?  @map("description")
  headId      String?  @map("head_id")
  parentId    String?  @map("parent_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  head        Employee?    @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Department[] @relation("DepartmentHierarchy")
  employees   Employee[]
  jobPostings JobPosting[]

  @@map("departments")
}

model Designation {
  id        String   @id @default(uuid()) @map("id")
  title     String   @unique @map("title")
  level     Int      @map("level")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees Employee[]

  @@map("designations")
}

// =============================================================================
// EMPLOYEE (also serves as Auth User)
// =============================================================================

model Employee {
  id              String         @id @default(uuid()) @map("id")
  employeeNo      String         @unique @map("employee_no")
  deviceId        String?        @map("device_id")

  // Identity
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  email           String         @unique @map("email")
  personalEmail   String?        @map("personal_email")
  phone           String?        @map("phone")
  personalPhone   String?        @map("personal_phone")

  // Personal info
  dateOfBirth     DateTime?      @db.Date @map("date_of_birth")
  gender          Gender?        @map("gender")
  nationality     String?        @map("nationality")
  bloodGroup      String?        @map("blood_group")
  profilePhoto    String?        @map("profile_photo")

  // Addresses & emergency contact (JSON)
  currentAddress   Json?         @map("current_address")
  permanentAddress Json?         @map("permanent_address")
  emergencyContact Json?         @map("emergency_contact")

  // Employment
  departmentId    String?        @map("department_id")
  designationId   String?        @map("designation_id")
  managerId       String?        @map("manager_id")
  employmentType  EmploymentType @default(FULL_TIME) @map("employment_type")
  status          EmployeeStatus @default(ACTIVE) @map("status")
  dateOfJoining   DateTime?      @db.Date @map("date_of_joining")
  probationEndDate DateTime?     @db.Date @map("probation_end_date")
  confirmationDate DateTime?     @db.Date @map("confirmation_date")
  workLocation    String?        @map("work_location")
  resignationDate DateTime?      @db.Date @map("resignation_date")
  lastWorkingDate DateTime?      @db.Date @map("last_working_date")

  // Auth fields
  passwordHash    String?        @map("password_hash")
  isActive        Boolean        @default(true) @map("is_active")
  emailVerified   DateTime?      @map("email_verified")

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  department        Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation       Designation?  @relation(fields: [designationId], references: [id], onDelete: SetNull)
  manager           Employee?     @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates      Employee[]    @relation("EmployeeManager")
  departmentsHeaded Department[]  @relation("DepartmentHead")

  // Next-Auth
  accounts          Account[]
  sessions          Session[]

  // PBAC
  employeeRoles     EmployeeRole[]

  // Audit
  auditLogs         AuditLog[]

  // Documents
  documents         Document[]    @relation("EmployeeDocuments")

  // Notifications
  notifications     Notification[]

  // Attendance
  attendanceLogs    AttendanceLog[]

  // Leave
  leaveRequests     LeaveRequest[]  @relation("LeaveRequests")
  leaveApprovals    LeaveRequest[]  @relation("LeaveApprovals")
  leaveBalances     LeaveBalance[]

  // Payroll
  salaryStructure   SalaryStructure?
  payrollRecords    PayrollRecord[]

  // Projects
  projectMemberships ProjectMember[]
  assignedTasks      ProjectTask[]   @relation("TaskAssignee")
  createdTasks       ProjectTask[]   @relation("TaskCreator")
  timesheets         Timesheet[]
  ownedProjects      Project[]       @relation("ProjectOwner")

  // Performance
  selfReviews        PerformanceReview[] @relation("Reviewee")
  managerReviews     PerformanceReview[] @relation("Reviewer")
  goals              Goal[]

  // Recruitment
  jobPostings        JobPosting[]    @relation("PostingCreator")
  interviews         Interview[]     @relation("Interviewer")

  // M12
  gpsCheckIns        GpsCheckIn[]

  // Password reset
  passwordResets     PasswordReset[]

  @@map("employees")
}

// =============================================================================
// DOCUMENT
// =============================================================================

model Document {
  id            String           @id @default(uuid()) @map("id")
  title         String           @map("title")
  description   String?          @map("description")
  category      DocumentCategory @default(OTHER) @map("category")
  fileName      String           @map("file_name")
  fileSize      Int              @map("file_size")
  mimeType      String           @map("mime_type")
  objectKey     String           @map("object_key")
  version       Int              @default(1) @map("version")
  employeeId    String?          @map("employee_id")
  uploadedById  String           @map("uploaded_by_id")
  isCompanyDoc  Boolean          @default(false) @map("is_company_doc")
  expiresAt     DateTime?        @map("expires_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  employee Employee? @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([category])
  @@index([isCompanyDoc])
  @@map("documents")
}

// =============================================================================
// EMAIL TEMPLATES & LOGS
// =============================================================================

model EmailTemplate {
  id          String   @id @default(uuid()) @map("id")
  slug        String   @unique @map("slug")
  name        String   @map("name")
  subject     String   @map("subject")
  bodyHtml    String   @db.Text @map("body_html")
  bodyText    String?  @db.Text @map("body_text")
  mergeFields String[] @map("merge_fields")
  isActive    Boolean  @default(true) @map("is_active")
  trigger     String?  @map("trigger")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  emailLogs EmailLog[]

  @@map("email_templates")
}

model EmailLog {
  id             String        @id @default(uuid()) @map("id")
  templateId     String?       @map("template_id")
  recipientEmail String        @map("recipient_email")
  subject        String        @map("subject")
  status         String        @default("queued") @map("status")
  error          String?       @map("error")
  sentAt         DateTime?     @map("sent_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  template EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

// =============================================================================
// NOTIFICATION
// =============================================================================

model Notification {
  id         String    @id @default(uuid()) @map("id")
  employeeId String    @map("employee_id")
  title      String    @map("title")
  message    String    @map("message")
  type       String    @map("type")
  link       String?   @map("link")
  isRead     Boolean   @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// ATTENDANCE (M3)
// =============================================================================

model HikvisionDevice {
  id           String    @id @default(uuid()) @map("id")
  name         String    @map("name")
  deviceSerial String    @unique @map("device_serial")
  ipAddress    String    @map("ip_address")
  port         Int       @default(8000) @map("port")
  username     String    @default("admin") @map("username")
  password     String    @map("password")
  location     String?   @map("location")
  isActive     Boolean   @default(true) @map("is_active")
  lastSyncAt   DateTime? @map("last_sync_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  attendanceLogs AttendanceLog[]

  @@map("hikvision_devices")
}

model AttendanceLog {
  id         String           @id @default(uuid()) @map("id")
  employeeId String           @map("employee_id")
  deviceId   String?          @map("device_id")
  date       DateTime         @db.Date @map("date")
  checkIn    DateTime?        @map("check_in")
  checkOut   DateTime?        @map("check_out")
  workHours  Float?           @map("work_hours")
  status     AttendanceStatus @default(PRESENT) @map("status")
  isManual   Boolean          @default(false) @map("is_manual")
  source     String?          @map("source")
  notes      String?          @map("notes")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  employee Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   HikvisionDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@map("attendance_logs")
}

model Holiday {
  id          String   @id @default(uuid()) @map("id")
  name        String   @map("name")
  date        DateTime @db.Date @map("date")
  description String?  @map("description")
  isOptional  Boolean  @default(false) @map("is_optional")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date, name])
  @@map("holidays")
}

model AttendancePolicy {
  id               String   @id @default(uuid()) @map("id")
  name             String   @unique @map("name")
  workHoursPerDay  Float    @default(8) @map("work_hours_per_day")
  workDaysPerWeek  Int      @default(5) @map("work_days_per_week")
  checkInTime      String   @default("09:00") @map("check_in_time")
  checkOutTime     String   @default("18:00") @map("check_out_time")
  lateGraceMins    Int      @default(15) @map("late_grace_mins")
  isDefault        Boolean  @default(false) @map("is_default")
  officeLatitude   Float?   @map("office_latitude")
  officeLongitude  Float?   @map("office_longitude")
  geoFenceRadius   Int      @default(200) @map("geo_fence_radius")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("attendance_policies")
}

// =============================================================================
// LEAVE MANAGEMENT (M4)
// =============================================================================

model LeaveType {
  id               String   @id @default(uuid()) @map("id")
  name             String   @unique @map("name")
  code             String   @unique @map("code")
  description      String?  @map("description")
  isPaid           Boolean  @default(true) @map("is_paid")
  maxDaysPerYear   Int      @default(0) @map("max_days_per_year")
  carryForward     Boolean  @default(false) @map("carry_forward")
  maxCarryDays     Int      @default(0) @map("max_carry_days")
  requiresApproval Boolean  @default(true) @map("requires_approval")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@map("leave_types")
}

model LeaveBalance {
  id          String   @id @default(uuid()) @map("id")
  employeeId  String   @map("employee_id")
  leaveTypeId String   @map("leave_type_id")
  year        Int      @map("year")
  allocated   Float    @default(0) @map("allocated")
  used        Float    @default(0) @map("used")
  pending     Float    @default(0) @map("pending")
  carried     Float    @default(0) @map("carried")

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id              String      @id @default(uuid()) @map("id")
  employeeId      String      @map("employee_id")
  leaveTypeId     String      @map("leave_type_id")
  startDate       DateTime    @db.Date @map("start_date")
  endDate         DateTime    @db.Date @map("end_date")
  totalDays       Float       @map("total_days")
  reason          String?     @map("reason")
  status          LeaveStatus @default(PENDING) @map("status")
  approverId      String?     @map("approver_id")
  approvedAt      DateTime?   @map("approved_at")
  rejectionReason String?     @map("rejection_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  employee  Employee  @relation("LeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
  approver  Employee? @relation("LeaveApprovals", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// =============================================================================
// PAYROLL (M5)
// =============================================================================

model SalaryStructure {
  id               String   @id @default(uuid()) @map("id")
  employeeId       String   @unique @map("employee_id")
  basicSalary      Float    @map("basic_salary")
  hra              Float    @default(0) @map("hra")
  conveyance       Float    @default(0) @map("conveyance")
  medicalAllowance Float    @default(0) @map("medical_allowance")
  otherAllowances  Float    @default(0) @map("other_allowances")
  pfEmployee       Float    @default(0) @map("pf_employee")
  pfEmployer       Float    @default(0) @map("pf_employer")
  esi              Float    @default(0) @map("esi")
  tds              Float    @default(0) @map("tds")
  effectiveFrom    DateTime @db.Date @map("effective_from")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRecords PayrollRecord[]

  @@map("salary_structures")
}

model PayrollRecord {
  id                String        @id @default(uuid()) @map("id")
  employeeId        String        @map("employee_id")
  salaryStructureId String?       @map("salary_structure_id")
  month             Int           @map("month")
  year              Int           @map("year")
  workingDays       Int           @map("working_days")
  presentDays       Float         @map("present_days")
  leaveDays         Float         @default(0) @map("leave_days")
  lopDays           Float         @default(0) @map("lop_days")

  // Earnings
  basicSalary       Float         @map("basic_salary")
  hra               Float         @default(0) @map("hra")
  conveyance        Float         @default(0) @map("conveyance")
  medicalAllowance  Float         @default(0) @map("medical_allowance")
  otherAllowances   Float         @default(0) @map("other_allowances")
  overtime          Float         @default(0) @map("overtime")
  grossSalary       Float         @map("gross_salary")

  // Deductions
  pfEmployee        Float         @default(0) @map("pf_employee")
  pfEmployer        Float         @default(0) @map("pf_employer")
  esi               Float         @default(0) @map("esi")
  tds               Float         @default(0) @map("tds")
  otherDeductions   Float         @default(0) @map("other_deductions")
  totalDeductions   Float         @map("total_deductions")

  netSalary         Float         @map("net_salary")
  status            PayrollStatus @default(DRAFT) @map("status")
  processedAt       DateTime?     @map("processed_at")
  approvedById      String?       @map("approved_by_id")
  paidAt            DateTime?     @map("paid_at")
  notes             String?       @map("notes")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salaryStructure SalaryStructure? @relation(fields: [salaryStructureId], references: [id], onDelete: SetNull)

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@index([status])
  @@map("payroll_records")
}

// =============================================================================
// PROJECTS & TASKS (M9)
// =============================================================================

model Project {
  id          String        @id @default(uuid()) @map("id")
  name        String        @map("name")
  description String?       @db.Text @map("description")
  code        String        @unique @map("code")
  status      ProjectStatus @default(PLANNING) @map("status")
  priority    TaskPriority  @default(MEDIUM) @map("priority")
  ownerId     String        @map("owner_id")
  startDate   DateTime?     @db.Date @map("start_date")
  endDate     DateTime?     @db.Date @map("end_date")
  budget      Float?        @map("budget")
  isArchived  Boolean       @default(false) @map("is_archived")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner      Employee        @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members    ProjectMember[]
  tasks      ProjectTask[]
  timesheets Timesheet[]

  @@index([status])
  @@index([ownerId])
  @@map("projects")
}

model ProjectMember {
  id         String     @id @default(uuid()) @map("id")
  projectId  String     @map("project_id")
  employeeId String     @map("employee_id")
  role       MemberRole @default(MEMBER) @map("role")
  joinedAt   DateTime   @default(now()) @map("joined_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@map("project_members")
}

model ProjectTask {
  id             String       @id @default(uuid()) @map("id")
  projectId      String       @map("project_id")
  title          String       @map("title")
  description    String?      @db.Text @map("description")
  status         TaskStatus   @default(TODO) @map("status")
  priority       TaskPriority @default(MEDIUM) @map("priority")
  assigneeId     String?      @map("assignee_id")
  creatorId      String       @map("creator_id")
  startDate      DateTime?    @db.Date @map("start_date")
  dueDate        DateTime?    @db.Date @map("due_date")
  completedAt    DateTime?    @map("completed_at")
  estimatedHours Float?       @map("estimated_hours")
  loggedHours    Float        @default(0) @map("logged_hours")
  tags           String[]     @map("tags")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   Employee?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator    Employee    @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  timesheets Timesheet[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@map("project_tasks")
}

model Timesheet {
  id         String   @id @default(uuid()) @map("id")
  projectId  String   @map("project_id")
  taskId     String?  @map("task_id")
  employeeId String   @map("employee_id")
  date       DateTime @db.Date @map("date")
  hours      Float    @map("hours")
  notes      String?  @map("notes")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     ProjectTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([employeeId])
  @@index([date])
  @@map("timesheets")
}

// =============================================================================
// PERFORMANCE EVALUATION (M6)
// =============================================================================

model ReviewCycle {
  id        String   @id @default(uuid()) @map("id")
  name      String   @map("name")
  year      Int      @map("year")
  quarter   Int?     @map("quarter")
  startDate DateTime @db.Date @map("start_date")
  endDate   DateTime @db.Date @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  reviews PerformanceReview[]

  @@map("review_cycles")
}

model PerformanceReview {
  id              String       @id @default(uuid()) @map("id")
  cycleId         String       @map("cycle_id")
  revieweeId      String       @map("reviewee_id")
  reviewerId      String?      @map("reviewer_id")
  status          ReviewStatus @default(PENDING) @map("status")
  selfRating      Float?       @map("self_rating")
  selfComments    String?      @db.Text @map("self_comments")
  achievements    String?      @db.Text @map("achievements")
  improvements    String?      @db.Text @map("improvements")
  managerRating   Float?       @map("manager_rating")
  managerComments String?      @db.Text @map("manager_comments")
  taskScore       Float?       @map("task_score")
  finalRating     Float?       @map("final_rating")
  submittedAt     DateTime?    @map("submitted_at")
  completedAt     DateTime?    @map("completed_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  cycle    ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  reviewee Employee    @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer Employee?   @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([cycleId, revieweeId])
  @@index([status])
  @@map("performance_reviews")
}

model Goal {
  id          String     @id @default(uuid()) @map("id")
  employeeId  String     @map("employee_id")
  title       String     @map("title")
  description String?    @db.Text @map("description")
  targetDate  DateTime?  @db.Date @map("target_date")
  progress    Int        @default(0) @map("progress")
  status      GoalStatus @default(NOT_STARTED) @map("status")
  year        Int        @map("year")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("goals")
}

// =============================================================================
// RECRUITMENT (M7)
// =============================================================================

model JobPosting {
  id             String     @id @default(uuid()) @map("id")
  title          String     @map("title")
  departmentId   String?    @map("department_id")
  description    String?    @db.Text @map("description")
  requirements   String?    @db.Text @map("requirements")
  location       String?    @map("location")
  type           String     @default("FULL_TIME") @map("type")
  salaryMin      Float?     @map("salary_min")
  salaryMax      Float?     @map("salary_max")
  status         JobStatus  @default(DRAFT) @map("status")
  openings       Int        @default(1) @map("openings")
  closingDate    DateTime?  @db.Date @map("closing_date")
  postedById     String     @map("posted_by_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  postedBy   Employee    @relation("PostingCreator", fields: [postedById], references: [id], onDelete: Restrict)
  applicants Applicant[]

  @@index([status])
  @@map("job_postings")
}

model Applicant {
  id              String         @id @default(uuid()) @map("id")
  jobPostingId    String         @map("job_posting_id")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  email           String         @map("email")
  phone           String?        @map("phone")
  resumeUrl       String?        @map("resume_url")
  coverLetter     String?        @db.Text @map("cover_letter")
  stage           ApplicantStage @default(APPLIED) @map("stage")
  rating          Int?           @map("rating")
  notes           String?        @db.Text @map("notes")
  source          String?        @map("source")
  rejectionReason String?        @map("rejection_reason")
  appliedAt       DateTime       @default(now()) @map("applied_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  jobPosting JobPosting  @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews Interview[]

  @@index([jobPostingId])
  @@index([stage])
  @@map("applicants")
}

model Interview {
  id            String          @id @default(uuid()) @map("id")
  applicantId   String          @map("applicant_id")
  interviewerId String?         @map("interviewer_id")
  type          InterviewType   @default(PHONE) @map("type")
  scheduledAt   DateTime        @map("scheduled_at")
  durationMins  Int             @default(60) @map("duration_mins")
  location      String?         @map("location")
  meetingLink   String?         @map("meeting_link")
  result        InterviewResult @default(PENDING) @map("result")
  feedback      String?         @db.Text @map("feedback")
  notes         String?         @db.Text @map("notes")
  rating        Int?            @map("rating")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  interviewer Employee? @relation("Interviewer", fields: [interviewerId], references: [id], onDelete: SetNull)

  @@index([applicantId])
  @@index([scheduledAt])
  @@map("interviews")
}

// =============================================================================
// M12 — MULTI-SOURCE ATTENDANCE
// =============================================================================

model QrSession {
  id        String   @id @default(uuid()) @map("id")
  token     String   @unique @map("token")
  expiresAt DateTime @map("expires_at")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("qr_sessions")
}

model GpsCheckIn {
  id         String   @id @default(uuid()) @map("id")
  employeeId String   @map("employee_id")
  type       String   @map("type")
  latitude   Float    @map("latitude")
  longitude  Float    @map("longitude")
  accuracy   Float?   @map("accuracy")
  timestamp  DateTime @map("timestamp")
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("gps_check_ins")
}

// =============================================================================
// PASSWORD RESET
// =============================================================================

model PasswordReset {
  id         String    @id @default(uuid()) @map("id")
  employeeId String    @map("employee_id")
  token      String    @unique @map("token")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}
