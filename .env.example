# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hrms_user:hrms_password_dev@localhost:5432/hrms?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MinIO (File Storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="hrms_minio"
MINIO_SECRET_KEY="hrms_minio_secret"
MINIO_BUCKET="hrms-documents"
MINIO_USE_SSL=false

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-at-least-32-characters-long"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="HRMS <noreply@company.com>"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="HRMS"
APP_URL="http://localhost:3000"
NODE_ENV="development"
